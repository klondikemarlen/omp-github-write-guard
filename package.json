{
  "name": "omp-repository-boundary-guard",
  "version": "1.4.1",
  "description": "Opt-in OMP confirmation guard for mutations outside the active repository boundary.",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "release:check": "bun run scripts/release-check.ts && tsc --noEmit && bun test",
    "handoff": "bun run bin/repository-mutation-handoff.ts",
    "reinstall": "omp plugin install github:klondikemarlen/omp-repository-boundary-guard"
  },
  "keywords": ["omp-plugin", "repository-boundary", "safety"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klondikemarlen/omp-repository-boundary-guard.git"
  },
  "omp": {
    "extensions": ["./index.ts"]
  },
  "pi": {
    "extensions": ["./index.ts"]
  },
  "dependencies": {
    "shell-quote": "^1.10.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
